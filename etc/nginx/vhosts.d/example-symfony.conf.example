# /etc/nginx/vhosts.d/example-symfony.conf.example
#
# Example nginx vhost for a Symfony application served via PHP-FPM.
# Requires a matching upstream defined in base.conf (e.g. "php-example").
#
# Prerequisites:
#   - Wildcard or domain-specific SSL certificate
#   - PHP-FPM pool listening on the socket defined in the upstream
#   - Symfony project deployed to the document root below

# --- HTTP redirect ---
# Redirect all HTTP traffic (with and without www) to HTTPS with www.
server {
    listen 80;
    listen [::]:80;
    server_name www.app.example.com app.example.com;

    return 301 https://www.app.example.com$request_uri;
}

# --- HTTPS non-www redirect ---
# Redirect bare domain over HTTPS to www variant.
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name app.example.com;

    ssl_certificate /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;

    return 301 https://www.app.example.com$request_uri;
}

# --- Main HTTPS server block ---
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name www.app.example.com;

    ssl_certificate /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;

    # Document root points to Symfony's public/ directory
    root /srv/www/vhosts/app.example.com/httpdocs/public;

    # Security headers (HSTS, X-Frame-Options, etc.)
    include vhosts.d/security-headers.global;
    fastcgi_hide_header X-Powered-By;

    # Upload limit — adjust to your application's needs
    client_max_body_size 256M;
    fastcgi_buffers 64 4K;

    # Gzip + Brotli compression
    include vhosts.d/compression.global;

    # Common Symfony protections (deny hidden files, config files, etc.)
    include vhosts.d/sf-common.global;

    # Long-term cache headers for static assets (CSS, JS, images, fonts)
    include vhosts.d/static-cache.global;

    # Symfony front controller — all requests go through index.php
    location / {
        try_files $uri /index.php$is_args$args;
    }

    # PHP-FPM handler
    location ~ \.php$ {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        include fastcgi.conf;
        fastcgi_param HTTP_PROXY "";
        fastcgi_param HTTPS $https;
        fastcgi_buffers 8 16k;
        fastcgi_buffer_size 32k;
        fastcgi_read_timeout 300s;
        client_body_buffer_size 128k;
        fastcgi_pass php-example;
    }

    error_log /var/log/nginx/app_example_com_error.log warn;
    access_log /var/log/nginx/app_example_com_access.log;
}
