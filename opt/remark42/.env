# /opt/remark42/.env
#
# IMPORTANT: SECRET must be long and random!
# Generate with: openssl rand -hex 32
SECRET=changeme

# Admin user ID — becomes visible after the first anonymous comment.
# Alternatively: email address when AUTH_EMAIL_ENABLE=true
ADMIN_SHARED_ID=changeme

# Email authentication (optional)
AUTH_EMAIL_ENABLE=true
AUTH_EMAIL_FROM=admin@example.com

# SMTP configuration (for email auth and admin notifications)
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USERNAME=admin@example.com
SMTP_PASSWORD=changeme

# Admin notifications
NOTIFY_EMAIL_FROM=admin@example.com
ADMIN_EMAIL=admin@example.com
